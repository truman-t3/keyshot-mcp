{
  "name": "keyshot-mcp",
  "version": "0.4.2",
  "mcpName": "io.github.truman-t3/keyshot-mcp",
  "description": "Local and portable MCP server for KeyShot headless scripting.",
  "type": "module",
  "homepage": "https://github.com/truman-t3/keyshot-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truman-t3/keyshot-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/truman-t3/keyshot-mcp/issues"
  },
  "bin": {
    "keyshot-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "status": "node ./dist/cli/status.js",
    "smoke:keyshot": "npm run build && node ./scripts/keyshot-smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "keyshot",
    "rendering",
    "keyshot-studio",
    "stdio"
  ],
  "files": [
    "dist",
    "scripts/keyshot_bridge.py",
    "scripts/keyshot-smoke.mjs",
    "examples",
    "assets/demo",
    "presets",
    "server.json",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
